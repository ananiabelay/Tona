datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. USER
model User {
  id                String   @id @default(uuid())
  username          String   @unique
  passwordHash      String
  email             String?  @unique

  age               Int
  gender            String
  area              String
  avatarId          Int      @default(1)
  bio               String?  @default("")

  isActive          Boolean  @default(true)
  lastSeenAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  vents             Vent[]
  comments          Comment[]
  ventFeels         VentFeel[]
  notifications     UserPrismaNotification[] @relation("UserNotifications")
  sentNotifications UserPrismaNotification[] @relation("NotificationSender")
  commentLikes      CommentLike[]
}

// 2. VENT
model Vent {
  id         String   @id @default(uuid())
  content    String
  status     String   @default("approved")
  visibility String   @default("public")
  isEdited   Boolean  @default(false)
  feelsCount Int      @default(0)
  tags       String   @default("")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  userId     String
  author     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  comments   Comment[]
  feels      VentFeel[]
}

// 3. COMMENT
model Comment {
  id         String   @id @default(uuid())
  content    String
  status     String   @default("approved")
  isEdited   Boolean  @default(false)
  likesCount Int      @default(0)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  ventId     String
  vent       Vent     @relation(fields: [ventId], references: [id], onDelete: Cascade)

  userId     String
  author     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  parentId   String?
  parent     Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[] @relation("CommentReplies")

  likes      CommentLike[]
}

// 4. NOTIFICATION
model UserPrismaNotification {
  id         String   @id @default(uuid())
  type       String
  entityType String
  entityId   String?
  actionUrl  String?

  isRead     Boolean  @default(false)
  readAt     DateTime?
  createdAt  DateTime @default(now())

  userId     String
  user       User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  senderId   String
  sender     User     @relation("NotificationSender", fields: [senderId], references: [id], onDelete: Cascade)
}

// 5. CONFIG
model AppConfig {
  id            String   @id @default("global_config")
  isMaintenance Boolean  @default(false)
  updatedAt     DateTime @updatedAt
}

// 6. VENT FEEL
model VentFeel {
  id        String   @id @default(uuid())
  userId    String
  ventId    String
  createdAt DateTime @default(now())

  @@unique([userId, ventId])

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  vent Vent @relation(fields: [ventId], references: [id], onDelete: Cascade)
}

// 7. COMMENT LIKE
model CommentLike {
  id        String   @id @default(uuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())

  @@unique([userId, commentId])

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
}
